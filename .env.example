# --- Auth ---
NEXTAUTH_URL=https://docs.regiq.in
NEXTAUTH_SECRET=

# --- Providers (Google is required; the others are optional) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# FACEBOOK_CLIENT_ID=
# FACEBOOK_CLIENT_SECRET=
# AUTH_MICROSOFT_ENTRA_ID_ID=
# AUTH_MICROSOFT_ENTRA_ID_SECRET=

# --- Public base URL (used for Stripe checkout success/cancel URLs, MCP config snippet) ---
PUBLIC_BASE_URL=https://docs.regiq.in

# --- Ingestion pipeline (all LLM calls via OpenRouter — never direct vendor SDKs) ---
OPENROUTER_API_KEY=
# Model IDs default to the cheapest capable options. Change here to try
# gemini-2.5-flash (better on messy scans, ~2x cost) or claude-haiku-4.5.
VISION_MODEL=google/gemini-2.5-flash-lite
EMBEDDING_MODEL=openai/text-embedding-3-small

# --- Stripe (test-mode keys until go-live) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Admin bypass ---
ADMIN_EMAILS=shreyas.pavuluri@gmail.com
